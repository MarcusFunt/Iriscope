IRISCOPE_HOST_PORT=8765
IRISCOPE_BIND_ADDRESS=127.0.0.1

# Use an IP address if mDNS names such as Iriscope.local do not resolve inside Docker.
IRISCOPE_PI_HOST=Iriscope.local
IRISCOPE_PI_USER=Iriscope
IRISCOPE_PI_PORT=22
IRISCOPE_PI_REMOTE_ROOT=/home/Iriscope/iriscope
IRISCOPE_PI_CONNECT_TIMEOUT=15

# Mount the SSH key into the container and point Iriscope at the mounted path.
IRISCOPE_SSH_KEY_HOST_PATH=C:/Users/marcu/.ssh/iriscope_rsa
IRISCOPE_SSH_KEY_CONTAINER_PATH=/run/secrets/iriscope_ssh_key
IRISCOPE_PI_SSH_KEY=/run/secrets/iriscope_ssh_key

# Set this before binding the API to a non-loopback address on a shared network.
IRISCOPE_ADMIN_TOKEN=

# Watchdog settings.
IRISCOPE_REPO_URL=https://github.com/MarcusFunt/Iriscope.git
IRISCOPE_BRANCH=main
IRISCOPE_WATCHDOG_INTERVAL_S=300
